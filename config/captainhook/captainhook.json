{
    "config": {
        "verbosity": "normal",
        "fail-on-first-error": true,
        "ansi-colors": true
    },
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "#^(feat|fix|chore|docs|test|refactor|style|ci|perf|build|revert)(\\(.+\\))?: .{1,72}$#"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "composer ci:test:php:lint",
                "conditions": []
            },
            {
                "action": "composer ci:test:php:cgl",
                "conditions": []
            },
            {
                "action": "composer ci:test:php:phpstan",
                "conditions": []
            }
        ]
    },
    "pre-push": {
        "enabled": true,
        "actions": [
            {
                "action": "composer ci:test:php:unit",
                "conditions": []
            }
        ]
    },
    "prepare-commit-msg": {
        "enabled": false,
        "actions": []
    },
    "post-merge": {
        "enabled": false,
        "actions": []
    },
    "post-checkout": {
        "enabled": false,
        "actions": []
    },
    "post-rewrite": {
        "enabled": false,
        "actions": []
    },
    "post-change": {
        "enabled": false,
        "actions": []
    }
}
